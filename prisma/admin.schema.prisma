// prisma/admin.schema.prisma
datasource db {
  provider = "mysql"
  url      = env("ADMIN_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "./generated/admin"
}

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  role            AdminRole @default(STAFF)
  suspended       Boolean  @default(false)
  suspended_number Int      @default(0)
  terminated      Boolean  @default(false) 
  phone           String    @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum AdminRole {
  ADMIN
  MANAGER
  STAFF
}

model OtpVerification {
  id         String   @id @default(cuid())
  email      String?
  token      String   @unique
  otp        String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  @@index([email])
  @@index([token])
}

model Office {
  id        String   @id @default(cuid())
  gstin     String   @unique
  address   String
  city      String?
  state     String
  stateCode String
  pincode   String?
  country   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String   @id @default(cuid())
  accountHolderName String
  accountNumber     String
  ifsc              String
  branch            String
  swiftCode         String?
  bankName          String
  isDefault         Boolean  @default(false) @map("default")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model EmailAccount {
  id          String   @id @default(cuid())
  fromEmail   String
  smtpHost    String   @default("smtp.hostinger.com")
  smtpPort    Int      @default(587)
  smtpUser    String
  smtpPassword String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([isActive])
}

/// Orders imported from CSV/Excel (admin bulk upload). One row per order; line items in ImportedOrderItem.
model ImportedOrder {
  id               String   @id @default(cuid())
  orderDate        DateTime @map("order_date")
  orderName        String   @map("order_name")
  deliveryCharges  Decimal  @map("delivery_charges") @db.Decimal(14, 2)
  orderTotal       Decimal  @map("order_total") @db.Decimal(14, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  items            ImportedOrderItem[]

  @@index([orderDate])
  @@index([orderName])
}

model ImportedOrderItem {
  id        String        @id @default(cuid())
  orderId   String        @map("order_id")
  order     ImportedOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  lineIndex Int           @map("line_index")
  itemName  String        @map("item_name")
  amount    Decimal       @db.Decimal(14, 2)

  @@index([orderId])
}


